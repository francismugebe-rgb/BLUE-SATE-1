# Nginx Reverse Proxy Configuration for Heart Connect
# Save this file on your VPS at: /etc/nginx/sites-available/heart.styni.com

server {
    listen 80;
    server_name heart.styni.com;

    # Redirect all HTTP traffic to HTTPS (uncomment after installing SSL)
    # return 301 https://$host$request_uri;

    location / {
        proxy_pass http://localhost:3000; # Points to your Node.js app
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Increase upload limit for photos/videos
    client_max_body_size 50M;
}

# --- SSL CONFIGURATION (Generated by Certbot) ---
# Once you run 'sudo certbot --nginx -d heart.styni.com', 
# Certbot will automatically add the SSL lines below.
