{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's full name" },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role in the system" },
        "points": { "type": "number", "description": "User's earned points" },
        "isVerified": { "type": "boolean", "description": "Whether the user is verified" },
        "proTier": { "type": "string", "enum": ["none", "bronze", "gold", "platinum"], "description": "User's pro membership tier" },
        "walletBalance": { "type": "number", "description": "User's wallet balance for payments" },
        "followers": { "type": "array", "items": { "type": "string" }, "description": "UIDs of users following this user" },
        "following": { "type": "array", "items": { "type": "string" }, "description": "UIDs of users this user is following" },
        "friends": { "type": "array", "items": { "type": "string" }, "description": "UIDs of friends" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["uid", "email", "role"]
    },
    "Match": {
      "title": "Match",
      "description": "A match between two users",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the match" },
        "users": { "type": "array", "items": { "type": "string" }, "description": "The UIDs of the two users in the match" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the match was created" }
      },
      "required": ["id", "users", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A post on the user's wall",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "isReel": { "type": "boolean" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "createdAt"]
    },
    "Reel": {
      "title": "Reel",
      "description": "A short vertical video",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "videoUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "description": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "views": { "type": "number" },
        "duration": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "videoUrl", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "seen": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "postId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "postId", "text", "createdAt"]
    },
    "FriendRequest": {
      "title": "Friend Request",
      "description": "A request to connect between two users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromId": { "type": "string" },
        "toId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fromId", "toId", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["friend_request", "friend_accept", "message", "like", "comment"] },
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "text": { "type": "string" },
        "link": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "text", "read", "createdAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment or wallet transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal", "pro_upgrade"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "method": { "type": "string" },
        "proofUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "amount", "type", "status", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings controlled by admin",
      "type": "object",
      "properties": {
        "pointValues": {
          "type": "object",
          "properties": {
            "post": { "type": "number" },
            "comment": { "type": "number" },
            "like": { "type": "number" }
          }
        },
        "proPrices": {
          "type": "object",
          "properties": {
            "bronze": { "type": "number" },
            "gold": { "type": "number" },
            "platinum": { "type": "number" }
          }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Match documents"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Wall posts"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a post"
    },
    "/settings/global": {
      "schema": "Settings",
      "description": "Global settings"
    },
    "/reels/{reelId}": {
      "schema": "Reel",
      "description": "Short videos"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Chat conversations"
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a conversation"
    },
    "/friendRequests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Friend requests"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment transactions"
    }
  }
}
