{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "location": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "photos": { "type": "array", "items": { "type": "string" } },
        "relationshipPreference": { "type": "string" },
        "occupation": { "type": "string" },
        "height": { "type": "number" },
        "lifestyle": { "type": "array", "items": { "type": "string" } },
        "matches": { "type": "array", "items": { "type": "string" } },
        "likes": { "type": "array", "items": { "type": "string" } },
        "dislikes": { "type": "array", "items": { "type": "string" } },
        "followers": { "type": "array", "items": { "type": "string" } },
        "following": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "User social feed post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "comments": { "type": "array", "items": { "$ref": "Comment" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "authorName", "content", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Post comment",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "comment", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "image": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "receiverId", "text", "read", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "receiverId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "type": { "type": "string", "enum": ["match", "message", "like", "comment", "follow"] },
        "relatedId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["receiverId", "senderId", "senderName", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "posts": {
      "schema": "Post",
      "description": "Social feed posts"
    },
    "notifications": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "chats/{chatId}/messages": {
      "schema": "Message",
      "description": "Messages within a chat"
    }
  }
}
