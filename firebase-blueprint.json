{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "interestedIn": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "location": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "photos": { "type": "array", "items": { "type": "string" } },
        "coverPhoto": { "type": "string" },
        "relationshipPreference": { "type": "string" },
        "relationshipStatus": { "type": "string" },
        "occupation": { "type": "string" },
        "height": { "type": "number" },
        "lifestyle": { "type": "array", "items": { "type": "string" } },
        "matches": { "type": "array", "items": { "type": "string" } },
        "likes": { "type": "array", "items": { "type": "string" } },
        "dislikes": { "type": "array", "items": { "type": "string" } },
        "followers": { "type": "array", "items": { "type": "string" } },
        "following": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isVerified": { "type": "boolean" },
        "isVerifiedPending": { "type": "boolean" },
        "isPremium": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "isSuspended": { "type": "boolean" },
        "suspensionUntil": { "type": "string", "format": "date-time" },
        "points": { "type": "number" },
        "walletBalance": { "type": "number" },
        "level": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "User social feed post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "linkPreview": { "type": "object" },
        "likes": { "type": "array", "items": { "type": "object" } },
        "comments": { "type": "array", "items": { "$ref": "Comment" } },
        "views": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "authorName", "content", "createdAt"]
    },
    "Page": {
      "title": "Page",
      "description": "User or Admin page",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "followers": { "type": "array", "items": { "type": "string" } },
        "profilePhoto": { "type": "string" },
        "coverPhoto": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "title", "createdAt"]
    },
    "Group": {
      "title": "Group",
      "description": "User or Admin group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "isPrivate": { "type": "boolean" },
        "coverPhoto": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "title", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "Content or user report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterId": { "type": "string" },
        "targetId": { "type": "string" },
        "targetType": { "type": "string", "enum": ["user", "post", "comment", "reel"] },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterId", "targetId", "targetType", "reason", "status", "createdAt"]
    },
    "Advert": {
      "title": "Advert",
      "description": "Sponsored advertisement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sponsorId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "type": { "type": "string", "enum": ["cpc", "impression"] },
        "budget": { "type": "number" },
        "spent": { "type": "number" },
        "cpcRate": { "type": "number" },
        "impressionRate": { "type": "number" },
        "clicks": { "type": "number" },
        "impressions": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "paused", "completed", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sponsorId", "title", "type", "budget", "status", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal", "payment", "points_conversion"] },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Post comment",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "comment", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "image": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "receiverId", "text", "read", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "receiverId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "type": { "type": "string", "enum": ["match", "message", "like", "comment", "follow"] },
        "relatedId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["receiverId", "senderId", "senderName", "type", "read", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Conversation between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "updatedAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "posts": {
      "schema": "Post",
      "description": "Social feed posts"
    },
    "notifications": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "chats": {
      "schema": "Chat",
      "description": "User conversations"
    },
    "chats/{chatId}/messages": {
      "schema": "Message",
      "description": "Messages within a chat"
    },
    "pages": {
      "schema": "Page",
      "description": "User and admin pages"
    },
    "groups": {
      "schema": "Group",
      "description": "User and admin groups"
    },
    "reports": {
      "schema": "Report",
      "description": "Content and user reports"
    },
    "adverts": {
      "schema": "Advert",
      "description": "Sponsored advertisements"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Wallet transactions"
    },
    "settings": {
      "schema": "object",
      "description": "Site settings"
    }
  }
}
