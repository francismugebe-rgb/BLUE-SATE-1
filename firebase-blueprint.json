{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "location": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "photos": { "type": "array", "items": { "type": "string" } },
        "relationshipPreference": { "type": "string" },
        "occupation": { "type": "string" },
        "height": { "type": "number" },
        "lifestyle": { "type": "array", "items": { "type": "string" } },
        "matches": { "type": "array", "items": { "type": "string" } },
        "likes": { "type": "array", "items": { "type": "string" } },
        "dislikes": { "type": "array", "items": { "type": "string" } },
        "followers": { "type": "array", "items": { "type": "string" } },
        "following": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "posts": {
      "title": "Post",
      "description": "Social feed post",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "comments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "comment": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "createdAt"]
    },
    "messages": {
      "title": "Message",
      "description": "Private message between users",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "image": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "receiverId", "text", "createdAt"]
    },
    "notifications": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "receiverId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "type": { "type": "string", "enum": ["match", "message", "like", "comment", "follow"] },
        "relatedId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["receiverId", "type", "createdAt"]
    }
  },
  "firestore": {
    "users": { "schema": "users", "description": "User profiles" },
    "posts": { "schema": "posts", "description": "Social feed posts" },
    "chats/{chatId}/messages": { "schema": "messages", "description": "Messages within a chat" },
    "notifications": { "schema": "notifications", "description": "User notifications" }
  }
}
