rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, fullName, username, email, phone, gender, interestedIn, age, bio, interests, photos, videoIntro, location, verificationStatus, premiumType, popularityScore, profileViews, lastSeen, online, createdAt
    
    // Collection: matches
    // Fields: users (array), compatibilityScore, createdAt, lastMessageAt
    
    // Collection: messages (subcollection of matches)
    // Fields: matchId, senderId, receiverId, text, mediaUrl, mediaType, seen, createdAt
    
    // Collection: posts
    // Fields: userId, authorName, authorPhoto, text, mediaUrls, likesCount, commentsCount, createdAt

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "FRANCISMUGEBE@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'username', 'gender', 'age']) &&
             data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() < 100 &&
             data.username is string && data.username.size() < 50 &&
             data.age is int && data.age >= 18;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['matchId', 'senderId', 'receiverId', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             (data.text is string || data.mediaUrl is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.users;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.users;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.users;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
        allow create: if isAuthenticated() && 
                        request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users &&
                        isValidMessage(request.resource.data);
      }
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
